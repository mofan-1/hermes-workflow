# ============================================
# Hermes Workflow Server 配置
# ============================================

# 飞书应用凭证（必填）
# 获取地址：https://open.feishu.cn → 创建企业自建应用
FEISHU_APP_ID=你的飞书应用ID
FEISHU_APP_SECRET=你的飞书应用Secret

# DeepSeek API 密钥（必填）
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=你的DeepSeek API Key

# DeepSeek 模型配置（可选，默认即可）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Obsidian 知识库路径（可选，默认 ~/hermes-workflow 下）
INBOX_VAULT_PATH=~/hermes-workflow/inbox-vault
DEEP_VAULT_PATH=~/hermes-workflow/deep-vault

# 服务端口（可选，默认 9000）
PORT=9000
